# === CORS ===
CORS_ORIGIN=http://localhost:3000   # produção: https://seu-dominio.com

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# === MySQL ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=espalhe_melodias
DB_CONNECTION_LIMIT=10

# === Admin Padrão (seed) ===
DEFAULT_ADMIN_EMAIL=karen.adm@melodias.com.br
