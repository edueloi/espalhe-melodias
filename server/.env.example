# === Servidor ===
PORT=3001
NODE_ENV=development   # production na VPS

# === JWT ===
JWT_SECRET=troque_por_uma_string_aleatoria_longa
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=troque_por_outra_string_aleatoria_longa
