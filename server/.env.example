# ═══════════════════════════════════════════════════════════════════════════
# Espalhe Melodias — Configurações de Ambiente
# ═══════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=sua_chave_secreta_super_longa_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=sua_chave_refresh_super_longa_aqui
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── MySQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=espalhe_melodias
DB_CONNECTION_LIMIT=10

# ─── Admin Padrão (seed) ──────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=karen.adm@melodias.com.br
DEFAULT_ADMIN_PASSWORD=melodias2026

# ─── Email Service ────────────────────────────────────────────────────────
# Provider: 'smtp' (recomendado), 'local' (não envia, só loga), 'sendgrid', ou 'mailchimp'
EMAIL_PROVIDER=smtp
EMAIL_FROM=contato@espalhemelodias.com.br
EMAIL_FROM_NAME=Espalhe Melodias

# SMTP (ex: Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

# SendGrid Configuration
SENDGRID_API_KEY=

# Mailchimp Configuration (Transactional Email)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# ─── Contact Form ─────────────────────────────────────────────────────────
CONTACT_ADMIN_EMAILS=admin1@espalhe-melodias.com,admin2@espalhe-melodias.com

# ─── App ──────────────────────────────────────────────────────────────────
# URL pública do frontend, usada para montar links em e-mails (reset de senha, convites)
APP_URL=http://localhost:3000

# ─── Instagram Integration ────────────────────────────────────────────────
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_CACHE_TTL=3600
INSTAGRAM_API_VERSION=v18.0
